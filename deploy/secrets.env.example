# GCP 資格情報・シークレット設定テンプレート
# 実際の値を記入して /etc/robot_nl/secrets.env にコピーする
# パーミッション: chmod 600 /etc/robot_nl/secrets.env
#                chown root:robot /etc/robot_nl/secrets.env

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Application Default Credentials のパス（Service Account を使う場合）
# GOOGLE_APPLICATION_CREDENTIALS=/etc/robot_nl/service_account.json

# モデル文字列を環境変数で上書きしたい場合（config.yaml の model_locked: false が必要）
# ROBOT_MODEL=claude-sonnet-4-5@20250514
