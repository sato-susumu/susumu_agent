# susumu_agent 環境変数設定サンプル
# このファイルをコピーして .env を作成し、各値を設定してください。
#
#   cp .env.sample .env
#
# .env は .gitignore で除外されているためコミットされません。

# ----------------------------------------
# Google Cloud / Vertex AI
# ----------------------------------------
# GCP プロジェクト ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI リージョン
GOOGLE_CLOUD_LOCATION=us-central1

# 使用モデル（gemini-2.5-flash / gemini-2.5-pro / claude-sonnet-4-5@20250514）
ROBOT_MODEL=gemini-2.5-flash
